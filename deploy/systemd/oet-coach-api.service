[Unit]
Description=OET Coach FastAPI
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/oet-coach/apps/api
EnvironmentFile=/opt/oet-coach/.env
Environment=ENVIRONMENT=production
ExecStart=/opt/oet-coach/apps/api/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
