# ── Auth email delivery (Profile status + branded magic link) ──
# Set to "branded" after Resend SMTP + Supabase template — see docs/07-IMPLEMENTATION/12-auth-email-resend-setup.md
# NEXT_PUBLIC_AUTH_EMAIL_DELIVERY=default

# ── Frontend (apps/web/.env.local) ──
# Copy NEXT_PUBLIC_* vars above into apps/web/.env.local
# Optional dev: extra hosts for HMR when testing from VM/LAN (comma-separated IPs)
# ALLOWED_DEV_ORIGINS=192.168.1.42

# ── Supabase Management API (optional — apply email template script) ──
# SUPABASE_ACCESS_TOKEN=sbp_...   # never commit; Dashboard → Account → Tokens
# SUPABASE_PROJECT_REF=fdbxisjilainlbsgdbry

# ── Supabase (create project at supabase.com) ──
# Root .env = backend secrets (docker compose + FastAPI)
# apps/web/.env.local = frontend only (NEXT_PUBLIC_*)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-jwt
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt
# Recommended for FastAPI — Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Google OAuth — also enable in Supabase Dashboard → Auth → Providers → Google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── FastAPI backend ──
API_URL=http://localhost:8000
# development | production — production disables /docs and limits /health detail
ENVIRONMENT=development
# Max authenticated API requests per user/IP per minute
API_RATE_LIMIT_PER_MINUTE=120
# Delete attempts older than this (admin purge endpoint)
DATA_RETENTION_DAYS=365
# Leave unset in dev to use the Next.js same-origin proxy (no CORS errors).
# Set only for production or when API runs on a different host.
# NEXT_PUBLIC_API_URL=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Local Docker services ──
DATABASE_URL=postgresql+asyncpg://oet:oet@localhost:5432/oet_coach
REDIS_URL=redis://localhost:6379/0

# ── Content packs (Layer B — Supabase Storage) ──
# Frontend: NEXT_PUBLIC_SUPABASE_URL → auto content-packs URL
# NEXT_PUBLIC_CONTENT_PACKS_BUCKET=content-packs
# Upload (reads repo root .env): pnpm pack:sync   (from repo root)
# Requires: SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY in root .env (never in .env.local)

# ── Nika AI tutor — Gemini → Groq → Ollama → rule fallback ──
# Put keys ONLY in this root .env — never in apps/web/.env.local (frontend must not see them).
#
# Google Gemini (primary LLM + optional embeddings):
#   1. Go to https://aistudio.google.com/apikey
#   2. Sign in with Google → "Create API key" → copy key
#   3. Free tier has RPM/RPD limits — enough for dev and light use
#   Docs: https://ai.google.dev/gemini-api/docs/api-key
#
GEMINI_API_KEY=
#
# Groq (backup LLM when Gemini is rate-limited):
#   1. Go to https://console.groq.com/
#   2. Sign up → API Keys → "Create API Key"
#   3. Free tier available (rate limits apply)
#
GROQ_API_KEY=
#
# Ollama (local LLM — free, runs on your PC; no Docker):
#   pnpm setup:ollama          # detect / install / pull model / write .env
#   pnpm setup:ollama:check    # status only
# Or install manually: https://ollama.com/download then `ollama pull llama3.2`
#
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_ENABLED=true
#
# DeepL — vocabulary translations (server only, never in apps/web/.env.local):
#   Free API keys end with :fx — https://www.deepl.com/pro-api
#
DEEPL_API_KEY=
#
# Optional tuning (defaults in apps/api/app/core/config.py):
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL=text-embedding-004
# CHAT_MODEL=gemini-2.0-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# AI_DAILY_QUOTA=15
#
# Admin (Phase 8) — set in apps/web/.env.local; must match SQL grant in 14-admin-panel-setup.md
# Hides Google on /login for this email; does not grant role by itself
# NEXT_PUBLIC_ADMIN_EMAIL=you@yourdomain.com
#
# Content packs — Supabase Storage (not AWS S3)
# pnpm pack:sync
#
# After adding keys: restart API (pnpm dev:api or docker compose restart api)
# Test: sign in → Nika tab → ask "How long is Reading Part A?"
