# Nika-AI / OET Coach — environment template
# Copy to `.env` (repo root) and `apps/web/.env.local` (frontend build-time vars).

# ══════════════════════════════════════════════════════════════════════════════
# Production (EC2) — required overrides
# ══════════════════════════════════════════════════════════════════════════════
# ENVIRONMENT=production
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# Do NOT set API_URL on EC2 — Next.js proxies /api/v1 via API_PROXY_URL (systemd).
#
# apps/web/.env.local (rebuild after any change):
#   NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
#   NEXT_PUBLIC_CONTENT_PACKS_BUCKET=content-packs
#   NEXT_PUBLIC_ADMIN_EMAIL=you@yourdomain.com
#
# Supabase Dashboard (HTTPS only in production):
#   Site URL: https://yourdomain.com
#   Redirect URLs: https://yourdomain.com/auth/callback
#
# Apply migrations: supabase db push (includes security advisor fixes)
# chmod 600 .env apps/web/.env.local on the server

# ══════════════════════════════════════════════════════════════════════════════
# Auth email delivery (Profile status + branded magic link)
# ══════════════════════════════════════════════════════════════════════════════
# Set to "branded" after Resend SMTP + Supabase template — see docs/07-IMPLEMENTATION/12-auth-email-resend-setup.md
# NEXT_PUBLIC_AUTH_EMAIL_DELIVERY=branded
# Public site URL — Open Graph, email links, canonical metadata (production: https://nika-oet.fun)
# NEXT_PUBLIC_SITE_URL=https://nika-oet.fun

# Optional dev: extra hosts for HMR when testing from VM/LAN (comma-separated IPs)
# ALLOWED_DEV_ORIGINS=192.168.1.42

# ══════════════════════════════════════════════════════════════════════════════
# Supabase Management API (optional — apply email template script)
# ══════════════════════════════════════════════════════════════════════════════
# SUPABASE_ACCESS_TOKEN=sbp_...   # never commit; Dashboard → Account → Tokens
# SUPABASE_PROJECT_REF=fdbxisjilainlbsgdbry

# ══════════════════════════════════════════════════════════════════════════════
# Resend — transactional email (magic link via Supabase SMTP; future app mail)
# ══════════════════════════════════════════════════════════════════════════════
# https://resend.com/api-keys — also used as Supabase SMTP password (user: resend)
# Domain nika-oet.fun must be verified in Resend before sending from noreply@nika-oet.fun
# RESEND_API_KEY=re_...

# ══════════════════════════════════════════════════════════════════════════════
# Supabase — root .env (backend secrets)
# ══════════════════════════════════════════════════════════════════════════════
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-jwt
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt
# FastAPI JWT verification — Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# Google OAuth — configure in Supabase Dashboard → Auth → Providers → Google
# (client ID/secret live in Supabase; not required in EC2 .env)
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...

# ══════════════════════════════════════════════════════════════════════════════
# Frontend — apps/web/.env.local (NEXT_PUBLIC_* baked in at build time)
# ══════════════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-jwt
NEXT_PUBLIC_CONTENT_PACKS_BUCKET=content-packs
# NEXT_PUBLIC_ADMIN_EMAIL=you@yourdomain.com
# Leave unset on EC2 — same-origin /api/v1 proxy (see deploy/systemd/Nika-AI-web.service)
# NEXT_PUBLIC_API_URL=

# ══════════════════════════════════════════════════════════════════════════════
# FastAPI backend
# ══════════════════════════════════════════════════════════════════════════════
# Local dev only — production uses same-origin proxy
API_URL=http://localhost:8000
# development | production — production disables /docs and limits /health detail
ENVIRONMENT=development
API_RATE_LIMIT_PER_MINUTE=120
DATA_RETENTION_DAYS=365
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ══════════════════════════════════════════════════════════════════════════════
# Local Docker services (optional — production uses Supabase)
# ══════════════════════════════════════════════════════════════════════════════
DATABASE_URL=postgresql+asyncpg://oet:oet@localhost:5432/oet_coach
REDIS_URL=redis://localhost:6379/0

# ══════════════════════════════════════════════════════════════════════════════
# Content packs (Layer B — Supabase Storage)
# ══════════════════════════════════════════════════════════════════════════════
# Upload from dev PC: pnpm pack:sync (needs SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY in root .env)

# ══════════════════════════════════════════════════════════════════════════════
# Nika AI tutor — Gemini → Groq → Ollama → rule fallback
# Keys ONLY in root .env — never in apps/web/.env.local
# ══════════════════════════════════════════════════════════════════════════════
# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Groq backup: https://console.groq.com/
GROQ_API_KEY=
# Ollama (local): pnpm setup:ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_ENABLED=true
# Production EC2: set OLLAMA_ENABLED=false when GEMINI_API_KEY or GROQ_API_KEY is set

# Nika knowledge brain — auto-sync on API startup (no manual scripts on deploy)
# Harvests phrases from apps/web/src/content + 12 profession packs on every API restart.
NIKA_AUTO_SYNC=true
NIKA_AUTO_ENRICH=true
NIKA_ENRICH_LIMIT=8
# NIKA_MERGE_GLOSSARY_STUBS=false   # placeholder rows for frequent harvest terms (default off)
# NIKA_MERGE_MIN_OCCURRENCES=8
# Docs: docs/04-AI-TUTOR/09-nika-knowledge-brain.md
# (local Ollama on t3.micro is too slow for live chat; cloud keys are preferred)
# DeepL vocabulary: https://www.deepl.com/pro-api (free keys end with :fx)
# Used by /api/v1/vocabulary/translate and one-click save on /vocabulary
DEEPL_API_KEY=

# Optional tuning (defaults in apps/api/app/core/config.py):
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL=text-embedding-004
# CHAT_MODEL=gemini-2.0-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# AI_DAILY_QUOTA=15
# NIKA_AUTO_SYNC=true
# NIKA_AUTO_ENRICH=true
# NIKA_ENRICH_LIMIT=8

# After adding keys: restart API (pnpm dev:api or systemctl restart Nika-AI-api)
